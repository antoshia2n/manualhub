{
  "manifest_version": 3,
  "name": "Manual Hub",
  "version": "1.0",
  "description": "マニュアル・テンプレート・プロンプトをワンクリックで呼び出す",
  "permissions": ["clipboardWrite"],
  "host_permissions": ["https://manualhub.vercel.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Manual Hub"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
